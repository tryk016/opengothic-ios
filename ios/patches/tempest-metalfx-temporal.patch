+bool Encoder<CommandBuffer>::temporalUpscale(const TemporalScaler& scaler, const Attachment& color,
+                                             const ZBuffer& depth, const Attachment& motion,
+                                             StorageImage& output, const TemporalScalerArgs& args) {
+  if(scaler.isEmpty() || color.isEmpty() || depth.isEmpty() || motion.isEmpty() || output.isEmpty())
+    return false;
+  if(state.stage==Rendering)
+    impl->endRendering();
+  state = State();
+  auto& clr = *textureCast<const Texture2d&>(color).impl.handler;
+  auto& dep = *textureCast<const Texture2d&>(depth).impl.handler;
+  auto& mov = *textureCast<const Texture2d&>(motion).impl.handler;
+  auto& dst = *output.tImpl.impl.handler;
+  return impl->temporalUpscale(*scaler.impl.handler,clr,dep,mov,dst,args);
+  }
